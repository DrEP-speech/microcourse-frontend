# Frontend public env
#
# IMPORTANT: the variable name is NEXT_PUBLIC_API_BASE (no _URL suffix).
# This must point at the deployed backend's root URL (no trailing slash,
# no /api - the app code appends /api/... itself). On Vercel, set this to
# your Render backend URL, e.g. https://microcourse-backend.onrender.com
NEXT_PUBLIC_API_BASE=http://localhost:4000

NEXT_PUBLIC_APP_NAME=MicroCourse
NEXT_PUBLIC_APP_VERSION=1.0.0
